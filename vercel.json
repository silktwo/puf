{
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/catalog",
      "destination": "/catalog.html"
    },
    {
      "source": "/about",
      "destination": "/about.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}

